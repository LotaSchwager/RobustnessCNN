# --- Configuración General ---
DEBUG=false
DATASET=cifar10
MODEL=resnet18
USE_CUDA=true
DOWNLOAD=false          # SIEMPRE false en OCEANO (sin internet en nodos GPU)
NUM_WORKERS=4

# --- Reanudación de Experimentos ---
# RUN_ID="YYYYMMDD-HHMMSS"  # Descomentar e indicar la fecha exacta para continuar desde Temp/

# --- Hiperparámetros de Entrenamiento ---
BATCH_SIZE=128
TEST_BATCH_SIZE=256
EPOCHS=100
LR=0.1
MOMENTUM=0.9
WEIGHT_DECAY=5e-4
SEED=1

# --- Parámetros de Ataque (Epsilon 8/255 ≈ 0.0314, Step 2/255 ≈ 0.0078) ---
EPSILON=0.031372549
STEP_SIZE=0.007843137
NUM_STEPS=10

# --- Parámetros específicos de D-TRADES ---
ALPHA=1.0
BETA=1.0

# --- Registro y Guardado ---
LOG_INTERVAL=100
SAVE_FREQ=4              # Guarda checkpoint en Temp/ cada 4 épocas

# --- Metaheurística ---
USE_METAHEURISTIC=true   # true: optimiza alpha/beta cada época; false: valores fijos
