# --- Configuración Estructural ---
METHOD=mart
DATASET=cifar10
MODEL=resnet18
EPOCHS=100
USE_RANDAUGMENT=True

# --- Reanudación de Experimentos ---
# Opción A — Continuar desde la última época guardada automáticamente en Temp/:
#   Descomentar RUN_ID con la fecha del run a continuar.
# RUN_ID=YYYYMMDD-HHMMSS

# Opción B — Especificar directamente la ruta de un checkpoint .pt:
#   Útil si el checkpoint está en otro directorio o tiene nombre personalizado.
#   Al especificar CHECKPOINT_PATH, CHECKPOINT_EPOCH debe indicar la época
#   guardada en ese checkpoint para que el scheduler y las métricas sean correctos.
# CHECKPOINT_PATH=/ruta/absoluta/al/checkpoint.pt
# CHECKPOINT_EPOCH=45
